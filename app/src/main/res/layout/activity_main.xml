<?xml version="1.0" encoding="utf-8"?>
<!-- Root: full-screen gradient canvas for glassmorphism -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ── Decorative glow circles (purely visual) ── -->
    <!-- Top-left purple glow -->
    <View
        android:id="@+id/glow_purple"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-80dp"
        android:layout_marginTop="-80dp"
        android:alpha="0.35"
        android:background="@drawable/glow_circle_purple" />

    <!-- Bottom-right pink glow -->
    <View
        android:id="@+id/glow_pink"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-60dp"
        android:layout_marginBottom="-60dp"
        android:alpha="0.30"
        android:background="@drawable/glow_circle_pink" />

    <!-- ── Header glass panel ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/header_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_header_bg"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="52dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp"
        android:elevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TaskFlow"
                android:textColor="#FFFFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% Done"
                    android:textColor="#00BFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="16dp" />

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="#FFFFFFFF"
                    android:contentDescription="Settings" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_task_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 tasks remaining"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_filter_today"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/btn_primary_bg"
                android:text="Today"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_plan_day"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/glass_input_bg"
                android:text="Plan Day"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_calendar_maker"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/glass_input_bg"
                android:text="Calendar Maker"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null" />

            <ImageButton
                android:id="@+id/btn_calendar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/glass_input_bg"
                android:src="@android:drawable/ic_menu_today"
                android:tint="#FFFFFFFF"
                android:contentDescription="Calendar" />
        </LinearLayout>

        <!-- Search Bar -->
        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/glass_input_bg"
            android:hint="Search tasks..."
            android:textColorHint="#66FFFFFF"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:drawableTint="#CCFFFFFF"
            android:maxLines="1"
            android:inputType="text" />
    </LinearLayout>

    <!-- ── Task list ─────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="210dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="100dp"
        android:scrollbars="none" />

    <!-- ── FAB ───────────────────────────────────────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Add task"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#0052A5"
        app:borderWidth="1dp"
        app:elevation="8dp"
        app:tint="@android:color/white" />

    <!-- ── Boot Overlay ─────────────────────────────────── -->
    <RelativeLayout
        android:id="@+id/boot_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/tf_background"
        android:visibility="visible"
        android:elevation="20dp">

        <!-- Animated glow behind logo -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_centerInParent="true"
            android:background="@drawable/glow_circle_purple"
            android:alpha="0.6" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/ic_app_logo"
                android:layout_marginBottom="32dp"
                android:contentDescription="App Logo"
                android:elevation="10dp" />

            <ProgressBar
                android:id="@+id/boot_progress"
                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:progressTint="#00BFFF" />
        </LinearLayout>
    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
