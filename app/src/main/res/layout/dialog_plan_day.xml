<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/glass_dialog_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plan Your Day"
        android:textColor="#FFFFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Describe your day (e.g., 'Buy milk at 10am then gym at 2pm')"
        android:textColor="#CCE0E0FF"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/et_plan_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:background="@drawable/glass_input_bg"
            android:hint="Type your plan here..."
            android:textColorHint="#66FFFFFF"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:padding="14dp"
            android:gravity="top"
            android:inputType="textMultiLine" />

        <ImageButton
            android:id="@+id/btn_plan_voice"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#FFFFFFFF"
            android:contentDescription="Voice input" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_plan_cancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/btn_cancel_bg"
            android:text="Cancel"
            android:textColor="#CCE0E0FF"
            android:layout_marginEnd="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn_plan_submit"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/btn_primary_bg"
            android:text="Generate Tasks"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
