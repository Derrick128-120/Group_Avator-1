<?xml version="1.0" encoding="utf-8"?>
<!-- Each task is a glass card floating on the gradient background -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/glass_card_bg"
    android:elevation="6dp"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="12dp"
    android:paddingBottom="14dp"
    android:gravity="center_vertical">

    <!-- Checkbox -->
    <CheckBox
        android:id="@+id/cb_complete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="#00BFFF"
        android:layout_marginEnd="12dp" />

    <!-- Title + priority column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_task_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_priority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tv_alarm_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#99E0E0FF"
            android:textSize="11sp"
            android:visibility="gone"
            android:drawablePadding="4dp" />

        <TextView
            android:id="@+id/tv_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#99FFD700"
            android:textSize="11sp"
            android:visibility="gone"
            android:drawableStart="@android:drawable/ic_dialog_map"
            android:drawableTint="#99FFD700"
            android:drawablePadding="4dp" />

    </LinearLayout>

    <!-- Delete button -->
    <ImageButton
        android:id="@+id/btn_edit"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/content_desc_edit"
        android:src="@android:drawable/ic_menu_edit"
        android:layout_marginEnd="4dp"
        android:tint="#99FFFFFF" />

    <ImageButton
        android:id="@+id/btn_delete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        android:contentDescription="Delete task"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="#99FF6B6B" />

</LinearLayout>
