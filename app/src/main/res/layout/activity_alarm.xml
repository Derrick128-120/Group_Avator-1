<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tf_background"
    android:gravity="center"
    android:padding="32dp">

    <!-- Decorative glow circles -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="-100dp"
        android:layout_marginTop="-100dp"
        android:alpha="0.4"
        android:background="@drawable/glow_circle_purple" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="-100dp"
        android:layout_marginBottom="-100dp"
        android:alpha="0.3"
        android:background="@drawable/glow_circle_pink" />

    <TextView
        android:id="@+id/tv_alarm_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:text="@string/task_reminder"
        android:textColor="#CCE0E0FF"
        android:textSize="14sp"
        android:letterSpacing="0.2"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_task_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_alarm_title"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:textColor="#FFFFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center" />

    <ImageView
        android:id="@+id/iv_alarm_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_below="@id/tv_task_name"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:src="@drawable/ic_app_logo"
        android:contentDescription="@string/task_reminder"
        android:alpha="0.8" />

    <TextView
        android:id="@+id/tv_auto_dismiss_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/iv_alarm_icon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:textColor="#80CCE0E0"
        android:textSize="12sp"
        android:text="Auto-dismissing in 60s" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_snooze"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_cancel_bg"
            android:text="SNOOZE (5m)"
            android:textColor="#CCE0E0FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:elevation="8dp" />

        <Button
            android:id="@+id/btn_dismiss"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1.2"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_primary_bg"
            android:text="@string/btn_dismiss"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:elevation="8dp" />

    </LinearLayout>

</RelativeLayout>
